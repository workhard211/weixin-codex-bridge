# Public template only. Do not put real tokens, cookies, QR codes, or account
# secrets in this file.
#
# The bridge loads .env automatically when it is started from the project root.
# Values exported in your shell, terminal profile, process manager, or CI secret
# store take priority. If the file lives elsewhere, set CODEX_WEIXIN_ENV_FILE in
# the shell before launching the bridge.
#
# Most users should run `npm run init` instead of editing this file by hand.

# Codex workspace and runtime state.
CODEX_WEIXIN_CWD=<absolute-path-to-codex-workspace>
CODEX_WEIXIN_STATE_ROOT=
# Backward-compatible alias. If both roots are set, CODEX_WEIXIN_LOG_ROOT wins.
CODEX_WEIXIN_LOG_ROOT=
CODEX_HOME=

# Weixin account lookup. New users can run `npm run login`; credentials are
# saved under CODEX_WEIXIN_AUTH_ROOT/openclaw-weixin. OPENCLAW_STATE_DIR is only
# needed when reusing an existing OpenClaw login.
CODEX_WEIXIN_AUTH_ROOT=
OPENCLAW_STATE_DIR=
OPENCLAW_CONFIG_PATH=
CODEX_WEIXIN_ACCOUNT_ID=
CODEX_WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
CODEX_WEIXIN_BOT_TYPE=3
CODEX_WEIXIN_CHANNEL_VERSION=2.1.1

# Delivery mode: desktop-ui uses Codex Desktop automation; codex-cli uses the
# Codex CLI directly. MAX_PARALLEL only applies to codex-cli; desktop-ui stays
# single-lane so multiple workers do not compete for one Codex window.
CODEX_WEIXIN_DELIVERY_MODE=desktop-ui
CODEX_WEIXIN_CLI_FALLBACK=false
CODEX_WEIXIN_MAX_PARALLEL=3

# Codex Desktop session and app overrides.
CODEX_WEIXIN_AUTO_DESKTOP_SESSION=true
CODEX_WEIXIN_SESSION_ID=
CODEX_DESKTOP_APP_ID=
CODEX_WEIXIN_DESKTOP_INPUT_SCRIPT=./scripts/Send-CodexDesktopInput.ps1
CODEX_WEIXIN_DESKTOP_MODEL_SCRIPT=./scripts/Set-CodexDesktopModel.ps1
CODEX_WEIXIN_DESKTOP_RESPONSE_TIMEOUT_MS=900000

# Codex CLI settings.
# Required for codex-cli and for CODEX_WEIXIN_CLI_FALLBACK=true.
CODEX_CMD_PATH=
CODEX_WEIXIN_MODEL=gpt-5.4-mini

# Local console.
CODEX_WEIXIN_CONSOLE_ENABLED=true
CODEX_WEIXIN_CONSOLE_PORT=18790

# Polling and startup behavior.
CODEX_WEIXIN_POLL_TIMEOUT_MS=35000
CODEX_WEIXIN_RESUME_ALL=true
CODEX_WEIXIN_RESUME_LAST=true
CODEX_WEIXIN_SKIP_BACKLOG_ON_START=true

# Optional desktop automation debug output. Keep this ignored and local.
CODEX_DESKTOP_INPUT_DEBUG_DIR=
